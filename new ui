// ============ NAV BAR ============
@Composable
fun NavBar(
    visible: Boolean,
    tabs: List<TabItem>,
    onTabClick: (Int) -> Unit,
    onCloseTab: (Int) -> Unit,
    onNewTab: () -> Unit
) {
    val offsetX by animateDpAsState(
        targetValue = if (visible) 0.dp else 500.dp,
        animationSpec = tween(350, easing = EaseOutCubic),
        label = "navOffset"
    )

    Box(
        modifier = Modifier
            .fillMaxSize()
            .padding(start = 16.dp, end = 16.dp, bottom = 20.dp),
        contentAlignment = Alignment.BottomCenter
    ) {
        Box(
            modifier = Modifier
                .fillMaxWidth()
                .height(52.dp)
                .offset(x = offsetX)
                .clip(RoundedCornerShape(26.dp))
                .background(
                    Brush.linearGradient(
                        listOf(AuraColors.PurpleDeep, AuraColors.PurpleStart, AuraColors.PurpleEnd)
                    )
                )
                .shadow(16.dp, RoundedCornerShape(26.dp))
                .padding(horizontal = 8.dp, vertical = 7.dp)
        ) {
            Row(
                modifier = Modifier.fillMaxSize(),
                verticalAlignment = Alignment.CenterVertically,
                horizontalArrangement = Arrangement.spacedBy(6.dp)
            ) {
                val listState = rememberLazyListState()
                LaunchedEffect(tabs) {
                    val activeIdx = tabs.indexOfFirst { it.active }
                    if (activeIdx >= 0) listState.animateScrollToItem(activeIdx)
                }
                LazyRow(
                    state = listState,
                    modifier = Modifier.weight(1f),
                    horizontalArrangement = Arrangement.spacedBy(5.dp),
                    contentPadding = PaddingValues(horizontal = 2.dp)
                ) {
                    items(tabs, key = { it.id }) { tab ->
                        TabCircle(
                            tab = tab,
                            onClick = { onTabClick(tab.id) },
                            onClose = { onCloseTab(tab.id) }
                        )
                    }
                }
                Box(
                    modifier = Modifier
                        .size(38.dp)
                        .clip(CircleShape)
                        .background(Color(0x24FFFFFF))
                        .border(1.5.dp, Color(0x66FFFFFF), CircleShape)
                        .clickable { onNewTab() },
                    contentAlignment = Alignment.Center
                ) {
                    Icon(Icons.Filled.Add, null, tint = Color.White, modifier = Modifier.size(16.dp))
                }
            }
        }
    }
}

@Composable
fun TabCircle(tab: TabItem, onClick: () -> Unit, onClose: () -> Unit) {
    val page = DataRepository.pages[tab.url]
    val isActive = tab.active
    val bg = when {
        isActive -> AuraColors.Surface
        page != null -> Brush.linearGradient(listOf(page.colorStart, page.colorEnd))
        else -> Brush.linearGradient(listOf(AuraColors.Secondary, AuraColors.Secondary))
    }

    Box {
        Box(
            modifier = Modifier
                .size(38.dp)
                .clip(CircleShape)
                .then(
                    if (isActive) Modifier.background(AuraColors.Surface)
                    else Modifier.background(bg as Brush)
                )
                .border(1.5.dp, if (isActive) AuraColors.Surface else Color(0x2EFFFFFF), CircleShape)
                .clickable { onClick() },
            contentAlignment = Alignment.Center
        ) {
            if (tab.url == "aura://home") {
                Icon(
                    Icons.Filled.Home,
                    null,
                    tint = if (isActive) AuraColors.PurpleDeep else Color.White,
                    modifier = Modifier.size(16.dp)
                )
            } else if (page != null) {
                Text(
                    page.hero,
                    color = if (isActive) AuraColors.PurpleDeep else Color.White,
                    fontSize = 13.sp,
                    fontWeight = FontWeight.Bold
                )
            } else {
                Text(
                    (tab.title.firstOrNull() ?: '?').toString().uppercase(),
                    color = Color.White,
                    fontSize = 13.sp,
                    fontWeight = FontWeight.Bold
                )
            }
        }
        if (isActive) {
            Box(
                modifier = Modifier
                    .align(Alignment.BottomCenter)
                    .offset(y = 6.dp)
                    .size(4.dp)
                    .clip(CircleShape)
                    .border(1.5.dp, AuraColors.PurpleStart, CircleShape)
                    .background(AuraColors.Success)
            )
        }
    }
}

// ============ RIGHT EDGE SWIPE HANDLER ============
@Composable
fun RightEdgeSwipeHandler(
    screenWidthPx: Int,
    navVisible: Boolean,
    onShowNav: () -> Unit,
    onHideNav: () -> Unit
) {
    var dragAmount by remember { mutableFloatStateOf(0f) }
    var dragging by remember { mutableStateOf(false) }
    val edgeThresholdPx = with(LocalDensity.current) { 22.dp.toPx() }

    Box(
        modifier = Modifier
            .fillMaxSize()
            .pointerInput(screenWidthPx, navVisible) {
                detectHorizontalDragGestures(
                    onDragStart = { offset ->
                        val fromRight = !navVisible && offset.x >= screenWidthPx - edgeThresholdPx
                        val fromAnywhere = navVisible
                        if (fromRight || fromAnywhere) {
                            dragging = true
                            dragAmount = 0f
                        }
                    },
                    onDragEnd = {
                        if (dragging) {
                            if (dragAmount < -50f && !navVisible) onShowNav()
                            else if (dragAmount > 50f && navVisible) onHideNav()
                            dragging = false
                            dragAmount = 0f
                        }
                    },
                    onDragCancel = {
                        dragging = false
                        dragAmount = 0f
                    },
                    onHorizontalDrag = { _, dragAmountX ->
                        if (dragging) dragAmount += dragAmountX
                    }
                )
            }
    )
}

