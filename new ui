// ============ SUGGESTIONS PANEL ============
@Composable
fun SuggestionsPanel(
    visible: Boolean,
    history: List<String>,
    query: String,
    onClearHistory: () -> Unit,
    onSearch: (String) -> Unit,
    onNavigate: (String) -> Unit
) {
    AnimatedVisibility(
        visible = visible,
        enter = fadeIn(tween(200)) + scaleIn(tween(200), initialScale = 0.98f) + slideInVertically(tween(200), initialOffsetY = { -6 }),
        exit = fadeOut(tween(150)) + scaleOut(tween(150), targetScale = 0.98f)
    ) {
        Column(
            modifier = Modifier
                .padding(horizontal = 12.dp)
                .clip(RoundedCornerShape(24.dp))
                .background(AuraColors.Surface)
                .shadow(8.dp, RoundedCornerShape(24.dp))
                .heightIn(max = 500.dp)
                .verticalScroll(rememberScrollState())
        ) {
            if (query.isBlank()) {
                if (history.isNotEmpty()) {
                    SuggestionGroupHeader("Recent", "Clear", onClearHistory)
                    history.forEach { item ->
                        SuggestionRow(
                            iconBg = Color(0xFFF2F2F7),
                            iconColor = AuraColors.Secondary,
                            icon = { Icon(Icons.Filled.History, null, tint = AuraColors.Secondary, modifier = Modifier.size(12.dp)) },
                            text = item,
                            onClick = { onSearch(item) }
                        )
                    }
                    HorizontalDivider(color = Color(0xFFF0F0F2))
                }
                SuggestionGroupHeader("Trending", null, null)
                DataRepository.trending.forEach { item ->
                    SuggestionRow(
                        iconBg = Color(0xFFF2F2F7),
                        iconColor = AuraColors.Secondary,
                        icon = { Icon(Icons.Filled.TrendingUp, null, tint = AuraColors.Secondary, modifier = Modifier.size(12.dp)) },
                        text = item,
                        onClick = { onSearch(item) }
                    )
                }
            } else {
                val ql = query.lowercase()
                val sites = DataRepository.pages.filter { (u, p) ->
                    u.contains(ql) || p.title.lowercase().contains(ql)
                }
                if (sites.isNotEmpty()) {
                    SuggestionGroupHeader("Sites", null, null)
                    sites.forEach { (url, page) ->
                        Row(
                            modifier = Modifier
                                .fillMaxWidth()
                                .clickable { onNavigate(url) }
                                .padding(horizontal = 16.dp, vertical = 8.dp),
                            verticalAlignment = Alignment.CenterVertically,
                            horizontalArrangement = Arrangement.spacedBy(10.dp)
                        ) {
                            Box(
                                modifier = Modifier
                                    .size(30.dp)
                                    .clip(RoundedCornerShape(8.dp))
                                    .background(Brush.linearGradient(listOf(page.colorStart, page.colorEnd))),
                                contentAlignment = Alignment.Center
                            ) {
                                Text(page.hero, color = Color.White, fontSize = 13.sp, fontWeight = FontWeight.Bold)
                            }
                            Column(modifier = Modifier.weight(1f)) {
                                Text(
                                    highlightText(page.title, query),
                                    color = AuraColors.Primary,
                                    fontSize = 13.5.sp,
                                    fontWeight = FontWeight.Medium,
                                    maxLines = 1,
                                    overflow = TextOverflow.Ellipsis
                                )
                                Text(url, color = AuraColors.Secondary, fontSize = 11.sp, maxLines = 1)
                            }
                        }
                    }
                    HorizontalDivider(color = Color(0xFFF0F0F2))
                }
