// ============ APP SCREEN ============
@Composable
fun AuraBrowserApp() {
    val context = LocalContext.current
    val scope = rememberCoroutineScope()

    var tabs by remember {
        mutableStateOf(listOf(TabItem(1, "New Tab", "aura://home", true)))
    }
    var nextId by remember { mutableStateOf(2) }
    var searchHistory by remember { mutableStateOf(listOf("best apps", "weather")) }
    var searchMode by remember { mutableStateOf(false) }
    var isLoading by remember { mutableStateOf(false) }
    var navVisible by remember { mutableStateOf(false) }
    var currentUrl by remember { mutableStateOf("") }
    var webpageOpen by remember { mutableStateOf(false) }
    var webpageContent by remember { mutableStateOf<PageContent?>(null) }
    var webpageUrl by remember { mutableStateOf("") }
    var isSearchResult by remember { mutableStateOf(false) }
    var searchQuery by remember { mutableStateOf("") }
    var menuOpen by remember { mutableStateOf(false) }
    var confirmOpen by remember { mutableStateOf(false) }
    var toastMessage by remember { mutableStateOf<String?>(null) }
    var searchInput by remember { mutableStateOf("") }
    var screenWidthPx by remember { mutableIntStateOf(0) }

    fun showToast(msg: String) {
        toastMessage = msg
        scope.launch {
            delay(1400)
            toastMessage = null
        }
    }

    fun copyUrl() {
        if (currentUrl.isBlank() || currentUrl == "aura://home") return
        val clipboard = context.getSystemService(Context.CLIPBOARD_SERVICE) as ClipboardManager
        clipboard.setPrimaryClip(ClipData.newPlainText("url", currentUrl))
        showToast("Link copied!")
    }

    fun setHome() {
        tabs = tabs.map { if (it.active) it.copy(title = "New Tab", url = "aura://home") else it }
        webpageOpen = false
        webpageContent = null
        isSearchResult = false
        currentUrl = ""
    }

    fun navigateTo(url: String) {
        val page = DataRepository.pages[url] ?: run {
            showToast("Site unavailable")
            return
        }
        tabs = tabs.map { if (it.active) it.copy(title = page.title, url = url) else it }
        currentUrl = url
        if (searchMode) searchMode = false
        scope.launch {
            isLoading = true
            delay(300 + (0..150).random().toLong())
            webpageContent = page
            webpageUrl = url
            isSearchResult = false
            webpageOpen = true
            isLoading = false
        }
    }

    fun performSearch(query: String) {
        if (query.isBlank()) return
        searchHistory = (listOf(query) + searchHistory.filter { it != query }).take(10)
        tabs = tabs.map { if (it.active) it.copy(title = query, url = "google.com/search?q=$query") else it }
        if (searchMode) searchMode = false
        scope.launch {
            isLoading = true
            delay(300 + (0..150).random().toLong())
            searchQuery = query
            isSearchResult = true
            webpageContent = null
            webpageOpen = true
            isLoading = false
        }
    }

    fun newTab() {
        tabs = tabs.map { it.copy(active = false) } + TabItem(nextId, "New Tab", "aura://home", true)
        nextId++
        setHome()
        navVisible = false
        showToast("New tab")
    }

    fun switchTab(id: Int) {
        val target = tabs.find { it.id == id } ?: return
        if (target.active) {
            navVisible = false
            return
        }
        tabs = tabs.map { it.copy(active = it.id == id) }
        if (target.url == "aura://home") {
            setHome()
        } else if (target.url.startsWith("google.com/search")) {
            val q = target.title
            searchQuery = q
            isSearchResult = true
            webpageContent = null
            webpageOpen = true
            currentUrl = ""
        } else {
            val page = DataRepository.pages[target.url]
            if (page != null) {
                webpageContent = page
                webpageUrl = target.url
                isSearchResult = false
                webpageOpen = true
                currentUrl = target.url
            }
        }
        navVisible = false
        showToast("Switched: ${target.title}")
    }

    fun closeTab(id: Int) {
        tabs = tabs.filter { it.id != id }
        if (tabs.isEmpty()) {
            newTab()
            return
        }
        if (tabs.none { it.active }) {
            tabs = tabs.dropLast(1) + tabs.last().copy(active = true)
        }
        val active = tabs.find { it.active }
        active?.let { switchTab(it.id) }
        showToast("Tab closed")
    }

    // ============ UI ============
    Box(
        modifier = Modifier
            .fillMaxSize()
            .background(Color(0xFF0F0F12))
    ) {
        Box(
            modifier = Modifier
                .fillMaxSize()
                .padding(
                    start = 0.dp,
                    end = 0.dp,
                    top = if (LocalConfiguration.current.screenWidthDp >= 500) 0.dp else 0.dp,
                    bottom = 0.dp
                )
                .then(
                    if (LocalConfiguration.current.screenWidthDp >= 500)
                        Modifier
                            .padding(20.dp)
                            .clip(RoundedCornerShape(44.dp))
                            .border(10.dp, Color(0xFF0A0A0A), RoundedCornerShape(44.dp))
                    else Modifier
                )
                .background(AuraColors.Background)
                .onGloballyPositioned { screenWidthPx = it.size.width }
        ) {
            Column(modifier = Modifier.fillMaxSize()) {
                // Top progress
                TopProgressBar(isLoading = isLoading)

                // Search Header
                SearchHeader(
                    currentUrl = currentUrl,
                    searchMode = searchMode,
                    isLoading = isLoading,
                    searchInput = searchInput,
                    onSearchInputChanged = { searchInput = it },
                    onSearchBarClick = {
                        if (!searchMode && !isLoading) {
                            searchMode = true
                            searchInput = if (currentUrl.isBlank() || currentUrl == "aura://home") "" else currentUrl
                        }
                    },
                    onClearClick = { searchInput = "" },
                    onCopyClick = { copyUrl() },
                    onMenuClick = { menuOpen = true },
                    onSearch = { q ->
                        val v = q.trim()
                        if (v.isNotBlank()) {
                            if (v.contains(".") && !v.contains(" ") && !v.startsWith("http"))
                                navigateTo(v)
                            else
                                performSearch(v)
                        }
                    }
                )

                // Suggestions
                SuggestionsPanel(
                    visible = searchMode,
                    history = searchHistory,
                    query = searchInput,
                    onClearHistory = {
                        searchHistory = emptyList()
                        showToast("History cleared")
                    },
                    onSearch = { performSearch(it) },
                    onNavigate = { navigateTo(it) }
                )

                // Content area
                Box(modifier = Modifier.weight(1f).fillMaxWidth()) {
                    // Empty state / webpage
                    if (!webpageOpen) {
                        EmptyState()
                    } else if (isSearchResult) {
                        SearchResultsView(query = searchQuery, onNavigate = { navigateTo(it) })
                    } else {
                        webpageContent?.let { WebpageView(it, webpageUrl) }
                    }
                }
            }

            // Edge indicator (right side)
            EdgeIndicator(visible = !navVisible)

            // Nav bar (slides from right)
            NavBar(
                visible = navVisible,
                tabs = tabs,
                onTabClick = { switchTab(it) },
                onCloseTab = { closeTab(it) },
                onNewTab = { newTab() }
            )

            // Gesture overlay for right-edge swipe
            RightEdgeSwipeHandler(
                screenWidthPx = screenWidthPx,
                navVisible = navVisible,
                onShowNav = { navVisible = true },
                onHideNav = { navVisible = false }
            )

            // Menu sheet
            if (menuOpen) {
                MenuSheet(
                    onClose = { menuOpen = false },
                    onAction = { action ->
                        menuOpen = false
                        when (action) {
                            "goHome" -> setHome()
                            else -> showToast(action.removePrefix("show").replaceFirstChar { it.uppercase() })
                        }
                    }
                )
            }

            // Confirm sheet
            if (confirmOpen) {
                ConfirmSheet(
                    count = tabs.size,
                    onConfirm = {
                        tabs = listOf(TabItem(nextId, "New Tab", "aura://home", true))
                        nextId++
                        setHome()
                        confirmOpen = false
                        showToast("All closed")
                    },
                    onCancel = { confirmOpen = false }
                )
            }

            // Toast
            toastMessage?.let { ToastBar(it) }
        }
    }
}

// ============ TOP PROGRESS BAR ============
@Composable
fun TopProgressBar(isLoading: Boolean) {
    val progress by animateFloatAsState(
        targetValue = if (isLoading) 0.8f else 1f,
        animationSpec = tween(600, easing = EaseOutCubic),
        label = "progress"
    )
    val alpha by animateFloatAsState(
        targetValue = if (isLoading) 1f else 0f,
        animationSpec = tween(150),
        label = "alpha"
    )

    Box(
        modifier = Modifier
            .fillMaxWidth()
            .height(2.dp)
            .alpha(alpha)
            .drawBehind {
                val brush = if (isLoading) {
                    Brush.horizontalGradient(
                        listOf(AuraColors.PurpleDeep, AuraColors.PurpleEnd)
                    )
                } else {
                    Brush.horizontalGradient(listOf(AuraColors.Success, AuraColors.Success))
                }
                drawRect(
                    brush = brush,
                    size = Size(size.width * progress, size.height)
                )
            }
    )
}

val EaseOutCubic = CubicBezierEasing(0.33f, 1f, 0.68f, 1f)

// ============ EDGE INDICATOR ============
@Composable
fun EdgeIndicator(visible: Boolean) {
    val infiniteTransition = rememberInfiniteTransition(label = "pulse")
    val pulseAlpha by infiniteTransition.animateFloat(
        initialValue = 0.35f,
        targetValue = 0.7f,
        animationSpec = infiniteRepeatable(
            animation = tween(2000, easing = EaseInOut),
            repeatMode = RepeatMode.Reverse
        ),
        label = "pulseAlpha"
    )

    val alpha by animateFloatAsState(
        targetValue = if (visible) pulseAlpha else 0f,
        animationSpec = tween(200),
        label = "edgeAlpha"
    )

    Box(
        modifier = Modifier
            .fillMaxHeight()
            .width(3.dp)
            .align(Alignment.CenterEnd)
            .alpha(alpha)
            .drawBehind {
                val h = size.height * 0.15f
                val top = (size.height - h) / 2f
                drawRect(
                    brush = Brush.verticalGradient(
                        colors = listOf(
                            Color.Transparent,
                            AuraColors.PurpleStart.copy(alpha = 0.5f),
                            Color.Transparent
                        ),
                        startY = top,
                        endY = top + h
                    ),
                    topLeft = Offset(0f, top),
                    size = Size(size.width, h)
                )
            }
    )
}

// ============ SEARCH HEADER ============
@Composable
fun SearchHeader(
    currentUrl: String,
    searchMode: Boolean,
    isLoading: Boolean,
    searchInput: String,
    onSearchInputChanged: (String) -> Unit,
    onSearchBarClick: () -> Unit,
    onClearClick: () -> Unit,
    onCopyClick: () -> Unit,
    onMenuClick: () -> Unit,
    onSearch: (String) -> Unit
) {
    val focusRequester = remember { FocusRequester() }
    var isFocused by remember { mutableStateOf(false) }
    val borderColor by animateColorAsState(
        targetValue = when {
            isLoading -> AuraColors.PurpleStart
            isFocused -> AuraColors.Primary
            else -> AuraColors.Border
        },
        animationSpec = tween(120),
        label = "borderColor"
    )
    val bgColor by animateColorAsState(
        targetValue = if (isFocused) AuraColors.Surface else Color.Transparent,
        animationSpec = tween(120),
        label = "bgColor"
    )

    LaunchedEffect(searchMode) {
        if (searchMode) {
            delay(30)
            focusRequester.requestFocus()
        }
    }

    Row(
        modifier = Modifier
            .fillMaxWidth()
            .padding(horizontal = 12.dp, vertical = 8.dp),
        verticalAlignment = Alignment.CenterVertically,
        horizontalArrangement = Arrangement.spacedBy(6.dp)
    ) {
        Box(
            modifier = Modifier
                .weight(1f)
                .height(44.dp)
                .clip(RoundedCornerShape(26.dp))
                .background(bgColor)
                .border(1.5.dp, borderColor, RoundedCornerShape(26.dp))
                .clickable { onSearchBarClick() }
                .padding(horizontal = 12.dp),
            contentAlignment = Alignment.CenterStart
        ) {
            if (searchMode) {
                Row(
                    modifier = Modifier.fillMaxWidth(),
                    verticalAlignment = Alignment.CenterVertically,
                    horizontalArrangement = Arrangement.spacedBy(8.dp)
                ) {
                    BasicTextField(
                        value = searchInput,
                        onValueChange = onSearchInputChanged,
                        modifier = Modifier
                            .weight(1f)
                            .focusRequester(focusRequester)
                            .onFocusChanged { isFocused = it.isFocused },
                        textStyle = TextStyle(
                            color = AuraColors.Primary,
                            fontSize = 13.5.sp,
                            fontWeight = FontWeight.Medium
                        ),
                        cursorBrush = SolidColor(AuraColors.Primary),
                        singleLine = true,
                        keyboardOptions = KeyboardOptions(
                            keyboardType = KeyboardType.Uri,
                            imeAction = ImeAction.Search
                        ),
                        keyboardActions = KeyboardActions(onSearch = { onSearch(searchInput) }),
                        decorationBox = { innerTextField ->
                            Box(contentAlignment = Alignment.CenterStart) {
                                if (searchInput.isEmpty()) {
                                    Text(
                                        "Search or enter URL",
                                        color = AuraColors.Secondary,
                                        fontSize = 13.5.sp,
                                        fontWeight = FontWeight.Normal
                                    )
                                }
                                innerTextField()
                            }
                        }
                    )
                    if (searchInput.isNotEmpty()) {
                        CircleIconButton(
                            icon = {
                                Text(
                                    "✕",
                                    color = Color.White,
                                    fontSize = 9.sp,
                                    fontWeight = FontWeight.Bold
                                )
                            },
                            bg = AuraColors.ClearButton,
                            onClick = onClearClick
                        )
                    }
                }
            } else {
                Row(
                    modifier = Modifier.fillMaxWidth(),
                    verticalAlignment = Alignment.CenterVertically,
                    horizontalArrangement = Arrangement.spacedBy(8.dp)
                ) {
                    Text(
                        text = if (currentUrl.isBlank() || currentUrl == "aura://home") "Search or enter url" else currentUrl,
                        color = if (currentUrl.isBlank() || currentUrl == "aura://home") AuraColors.Secondary else AuraColors.Primary,
                        fontSize = 13.5.sp,
                        fontWeight = if (currentUrl.isBlank() || currentUrl == "aura://home") FontWeight.Medium else FontWeight.Medium,
                        maxLines = 1,
                        overflow = TextOverflow.Ellipsis,
                        modifier = Modifier.weight(1f)
                    )
                    if (currentUrl.isNotBlank() && currentUrl != "aura://home") {
                        CircleIconButton(
                            icon = {
                                Icon(
                                    Icons.Filled.ContentCopy,
                                    contentDescription = "Copy",
                                    tint = Color.White,
                                    modifier = Modifier.size(9.dp)
                                )
                            },
                            bg = AuraColors.Success,
                            onClick = onCopyClick
                        )
                    }
                }
            }
        }

        // Menu dot
        Box(
            modifier = Modifier
                .size(34.dp)
                .clip(CircleShape)
                .border(1.5.dp, AuraColors.Border, CircleShape)
                .clickable { onMenuClick() },
            contentAlignment = Alignment.Center
        ) {
            Column(
                horizontalAlignment = Alignment.CenterHorizontally,
                verticalArrangement = Arrangement.spacedBy(3.dp)
            ) {
                repeat(3) {
                    Box(
                        modifier = Modifier
                            .size(4.dp)
                            .background(AuraColors.Primary, CircleShape)
                    )
                }
            }
        }
    }
}

